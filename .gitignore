# ---- data & model artifacts (never commit) ----
# Ignore the CONTENTS of raw/processed, but keep the empty dirs (.gitkeep).
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
# keep small, clearly-synthetic examples under data/synthetic/ and examples/ tracked;
# but ignore anything large / bulk that lands in synthetic/
data/synthetic/*.parquet
data/synthetic/*.arrow
data/synthetic/*.jsonl
models/
adapters/
checkpoints/
*.safetensors
*.gguf
*.bin
*.pt
*.pth

# ---- experiment tracking ----
wandb/
mlruns/
mlflow.db
*.log

# ---- python ----
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ---- os / editor ----
.DS_Store
.idea/
.vscode/

# ---- secrets ----
.env
*.secret
